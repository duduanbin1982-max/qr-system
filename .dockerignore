onal: Nginx reverse proxy (use if you want port 80/443)
  nginx:
    image: nginx:1.24-alpine
    container_name: qr-nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx-docker.conf:/etc/nginx/conf.d/default.conf:ro
      - ./server.crt:/etc/nginx/ssl/server.crt:ro
      - ./server.key:/etc/nginx/ssl/server.key:ro
    depends_on:
      app:
        condition: service_healthy
    profiles:
      - with-nginx
er

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('https://127.0.0.1:3000/api/health')" || exit 1

CMD ["gunicorn", "-c", "gunicorn.conf.py", "server:app"]
